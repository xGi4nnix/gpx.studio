# Copy this file to .env and fill in your values.
# Used by docker-compose at build/runtime.

# Get a key at: https://cloud.maptiler.com
PUBLIC_MAPTILER_KEY=YOUR_MAPTILER_KEY

# Subpath for hosting (leave empty if served at the domain root, e.g. gpx.example.com)
# Set to e.g. "/gpx" if you serve at example.com/gpx
BASE_PATH=

# Host port the container is published on (container always listens on 80 internally)
HOST_PORT=3000
